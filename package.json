{
  "name": "Caterm",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "tauri": "bun run --filter web tauri --",
    "tauri:dev": "bun run --filter web desktop:dev",
    "tauri:build": "bun run --filter web desktop:build",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@Caterm/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Caterm/config": "workspace:*",
    "@biomejs/biome": "2.4.0",
    "react-grab": "^0.1.20",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "packageManager": "bun@1.3.4"
}
