# ============================================
# Server Environment Configuration (Example)
# ============================================
# 复制此文件为 .env 并填入真实值

# PostgreSQL Database Connection
# 格式: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Better Auth 认证密钥
# 生成: openssl rand -base64 32 (最少 32 字符)
BETTER_AUTH_SECRET=your-super-secret-key-minimum-32-characters-long

# 认证服务地址
# 开发: http://localhost:3002 (vite.config.ts 中配置的端口)
# 生产: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3002

# CORS 跨域允许来源
# 开发: http://localhost:5173 (Vite 默认端口)
# 生产: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:5173

# 数据加密密钥 (必须恰好 64 字符十六进制)
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcd

# 运行环境
# 可选: development | production | test
NODE_ENV=development
